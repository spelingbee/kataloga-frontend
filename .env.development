# Single-tenant Deployment Configuration
# Use this configuration for single-tenant deployments
# Replace 'restaurant-slug' with actual tenant slug

# API Configuration
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NUXT_PUBLIC_WEBSOCKET_URL=wss://api.menuapp.com

# Single-tenant Configuration
NUXT_PUBLIC_TENANT_SLUG=vkusnaya-pizza
NUXT_PUBLIC_MULTI_TENANT_MODE=false
NUXT_PUBLIC_DEFAULT_TENANT=restaurant-slug
NUXT_PUBLIC_TENANT_QUERY_PARAM=tenant
NUXT_PUBLIC_PRESERVE_TENANT_IN_URL=false
NUXT_PUBLIC_REQUIRE_TENANT_VALIDATION=true
NUXT_PUBLIC_TENANT_CACHE_TIMEOUT=3600000
NUXT_PUBLIC_ALLOW_TENANT_SWITCHING=false

# App Configuration (will be overridden by tenant branding)
NUXT_PUBLIC_APP_NAME=Restaurant Name

# Environment
NODE_ENV=production
NITRO_PRESET=node-server