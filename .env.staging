# Staging Environment Configuration

# API Configuration
NUXT_PUBLIC_API_BASE_URL=https://api-staging.menuapp.com
NUXT_PUBLIC_WEBSOCKET_URL=wss://api-staging.menuapp.com

# Multi-tenant Configuration (Staging - Multi-tenant mode)
NUXT_PUBLIC_TENANT_SLUG=
NUXT_PUBLIC_MULTI_TENANT_MODE=true
NUXT_PUBLIC_DEFAULT_TENANT=
NUXT_PUBLIC_TENANT_QUERY_PARAM=tenant
NUXT_PUBLIC_PRESERVE_TENANT_IN_URL=true
NUXT_PUBLIC_REQUIRE_TENANT_VALIDATION=true
NUXT_PUBLIC_TENANT_CACHE_TIMEOUT=300000
NUXT_PUBLIC_ALLOW_TENANT_SWITCHING=true

# Telegram Configuration
NUXT_PUBLIC_TELEGRAM_BOT_TOKEN=your_staging_telegram_bot_token

# App Configuration
NUXT_PUBLIC_APP_NAME=Menu Ordering App (Staging)

# Push Notifications
NUXT_PUBLIC_VAPID_PUBLIC_KEY=your_staging_vapid_public_key

# Security
NUXT_PUBLIC_SENTRY_DSN=your_staging_sentry_dsn

# Analytics
NUXT_PUBLIC_ANALYTICS_ID=your_staging_analytics_id

# Performance
NUXT_PUBLIC_CDN_URL=https://cdn-staging.menuapp.com

# Environment
NODE_ENV=staging

# Build optimizations
NITRO_PRESET=node-server
NUXT_TELEMETRY_DISABLED=1