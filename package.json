{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "build:production": "NODE_ENV=production node scripts/build-production.js",
    "build:optimized": "NODE_ENV=production node scripts/optimize-build.js",
    "build:staging": "NODE_ENV=staging nuxt build",
    "build:analyze": "ANALYZE=true nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "generate:production": "NODE_ENV=production nuxt generate",
    "preview": "nuxt preview",
    "preview:production": "NODE_ENV=production nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "nuxt typecheck",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "test:integration": "node scripts/test-integration.js",
    "test:e2e": "playwright test",
    "test:lighthouse": "lhci autorun",
    "test:performance": "node scripts/performance-test.js",
    "test:all": "pnpm test && pnpm test:integration",
    "optimize:css": "node scripts/optimize-css.js",
    "optimize:images": "node scripts/optimize-images.js",
    "analyze:bundle": "node scripts/analyze-bundle.js",
    "clean": "rimraf .nuxt .output dist node_modules/.cache",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/image": "^1.11.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/i18n": "^10.2.1",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/vue": "^8.55.0",
    "@stripe/stripe-js": "^8.6.3",
    "@telegram-apps/sdk": "^3.11.8",
    "@types/leaflet": "^1.9.21",
    "@types/lodash-es": "^4.17.12",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vite-pwa/nuxt": "^1.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.7.0",
    "leaflet": "^1.9.4",
    "lodash-es": "^4.17.23",
    "nuxt": "^4.2.2",
    "pinia": "^3.0.4",
    "prettier": "^3.8.0",
    "sass": "^1.97.2",
    "typescript": "^5.9.3",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^3.23.0",
    "@types/node": "^25.0.9",
    "@unhead/vue": "^2.1.2",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "fast-check": "^4.5.3",
    "happy-dom": "^15.11.7",
    "jsdom": "^25.0.1",
    "lightningcss": "^1.31.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.12"
  }
}