{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "build:production": "NODE_ENV=production node scripts/build-production.js",
    "build:staging": "NODE_ENV=staging nuxt build",
    "build:analyze": "ANALYZE=true nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "generate:production": "NODE_ENV=production nuxt generate",
    "preview": "nuxt preview",
    "preview:production": "NODE_ENV=production nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "nuxt typecheck",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "test:integration": "node scripts/test-integration.js",
    "test:e2e": "playwright test",
    "test:lighthouse": "lhci autorun",
    "test:all": "pnpm test && pnpm test:integration",
    "clean": "rimraf .nuxt .output dist node_modules/.cache",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@nuxt/eslint": "^1.9.0",
    "@nuxt/image": "^1.8.1",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@pinia/nuxt": "^0.11.2",
    "@telegram-apps/sdk": "^3.11.8",
    "@types/leaflet": "^1.9.21",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vite-pwa/nuxt": "^1.0.7",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.5.1",
    "leaflet": "^1.9.4",
    "nuxt": "^4.1.3",
    "pinia": "^3.0.3",
    "prettier": "^3.6.2",
    "sass": "^1.93.2",
    "typescript": "^5.9.2",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^3.20.1",
    "@vitest/coverage-v8": "^3.2.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^15.11.6",
    "jsdom": "^25.0.1",
    "vitest": "^3.2.0"
  }
}