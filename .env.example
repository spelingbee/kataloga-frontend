# API Configuration
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001
NUXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3001

# Multi-tenant Configuration
# Leave NUXT_PUBLIC_TENANT_SLUG empty for multi-tenant mode
# Set to specific tenant slug for single-tenant deployment
NUXT_PUBLIC_TENANT_SLUG=

# Multi-tenant mode settings
NUXT_PUBLIC_MULTI_TENANT_MODE=true
NUXT_PUBLIC_DEFAULT_TENANT=
NUXT_PUBLIC_TENANT_QUERY_PARAM=tenant
NUXT_PUBLIC_PRESERVE_TENANT_IN_URL=true
NUXT_PUBLIC_REQUIRE_TENANT_VALIDATION=true
NUXT_PUBLIC_TENANT_CACHE_TIMEOUT=300000
NUXT_PUBLIC_ALLOW_TENANT_SWITCHING=true

# Telegram Configuration
NUXT_PUBLIC_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# App Configuration
NUXT_PUBLIC_APP_NAME=Menu Ordering App

# Push Notifications
NUXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Environment
NODE_ENV=development