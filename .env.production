# Production Environment Configuration

# API Configuration
NUXT_PUBLIC_API_BASE_URL=https://api.menuapp.com
NUXT_PUBLIC_WEBSOCKET_URL=wss://api.menuapp.com

# Multi-tenant Configuration (Production - Can be single or multi-tenant)
# For single-tenant deployment, set NUXT_PUBLIC_TENANT_SLUG to specific tenant
# For multi-tenant deployment, leave NUXT_PUBLIC_TENANT_SLUG empty
NUXT_PUBLIC_TENANT_SLUG=
NUXT_PUBLIC_MULTI_TENANT_MODE=false
NUXT_PUBLIC_DEFAULT_TENANT=
NUXT_PUBLIC_TENANT_QUERY_PARAM=tenant
NUXT_PUBLIC_PRESERVE_TENANT_IN_URL=true
NUXT_PUBLIC_REQUIRE_TENANT_VALIDATION=true
NUXT_PUBLIC_TENANT_CACHE_TIMEOUT=600000
NUXT_PUBLIC_ALLOW_TENANT_SWITCHING=false

# Telegram Configuration
NUXT_PUBLIC_TELEGRAM_BOT_TOKEN=your_production_telegram_bot_token

# App Configuration
NUXT_PUBLIC_APP_NAME=Menu Ordering App

# Push Notifications
NUXT_PUBLIC_VAPID_PUBLIC_KEY=your_production_vapid_public_key

# Security
NUXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_for_error_tracking

# Analytics
NUXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# Performance
NUXT_PUBLIC_CDN_URL=https://cdn.menuapp.com

# Environment
NODE_ENV=production

# Build optimizations
NITRO_PRESET=node-server
NUXT_TELEMETRY_DISABLED=1