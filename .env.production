# Production Environment Configuration

# API Configuration
NUXT_PUBLIC_API_BASE_URL=https://api.menuapp.com
NUXT_PUBLIC_TENANT_SLUG=production
NUXT_PUBLIC_WEBSOCKET_URL=wss://api.menuapp.com

# Telegram Configuration
NUXT_PUBLIC_TELEGRAM_BOT_TOKEN=your_production_telegram_bot_token

# App Configuration
NUXT_PUBLIC_APP_NAME=Menu Ordering App

# Push Notifications
NUXT_PUBLIC_VAPID_PUBLIC_KEY=your_production_vapid_public_key

# Security
NUXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_for_error_tracking

# Analytics
NUXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# Performance
NUXT_PUBLIC_CDN_URL=https://cdn.menuapp.com

# Environment
NODE_ENV=production

# Build optimizations
NITRO_PRESET=node-server
NUXT_TELEMETRY_DISABLED=1